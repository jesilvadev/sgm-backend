# Copie este arquivo para .env e preencha os valores

# String de conexão com o banco de dados
# SQLite (desenvolvimento local) — padrão se não definir:
# DATABASE_URL=sqlite:///sgm.db

# PostgreSQL (produção) — cole a string do Supabase aqui:
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Chave secreta para sessões Flask (troque por algo seguro em produção)
SECRET_KEY=troque-esta-chave-por-uma-segura
